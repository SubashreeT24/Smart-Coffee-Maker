**Embedded C Code**
#include <reg52.h>

sbit IN1 = P2^0;
sbit IN2 = P2^1;
sbit IN3 = P2^2;
sbit IN4 = P2^3;

sbit BTN_A    = P1^0;
sbit BTN_B    = P1^1;
sbit BTN_AUTO = P1^2;

sbit SDA = P3^0;
sbit SCL = P3^1;
sbit IR  = P3^2;

#define OPEN_TIME        60
#define CLOSE_TIME       60
#define AUTO_COFFEE_TIME 1000
#define AUTO_SUGAR_TIME  700

#define LCD_ADDR  0x27
#define RS_BIT    0
#define EN_BIT    2
#define BL_BIT    3

void delay_ms(unsigned int ms)
{
    unsigned int i;
    unsigned int j;
    for(i = 0; i < ms; i++)
        for(j = 0; j < 123; j++)
            j = j;
}

void delay_us(unsigned int us)
{
    unsigned int i;
    for(i = 0; i < us; i++);
}

void i2c_start(void)
{
    SDA = 1; SCL = 1; delay_us(5);
    SDA = 0;          delay_us(5);
    SCL = 0;
}

void i2c_stop(void)
{
    SDA = 0; SCL = 1; delay_us(5);
    SDA = 1;          delay_us(5);
}

void i2c_write_byte(unsigned char val)
{
    unsigned char i;
    for(i = 0; i < 8; i++)
    {
        SDA = (val & 0x80) ? 1 : 0;
        val <<= 1;
        SCL = 1; delay_us(5);
        SCL = 0; delay_us(5);
    }
    SDA = 1;
    SCL = 1; delay_us(5);
    SCL = 0; delay_us(5);
}

void i2c_send(unsigned char val)
{
    i2c_start();
    i2c_write_byte((LCD_ADDR << 1) | 0);
    i2c_write_byte(val);
    i2c_stop();
}

void lcd_pulse_enable(unsigned char val)
{
    i2c_send(val | (1 << EN_BIT) | (1 << BL_BIT));
    delay_us(1);
    i2c_send((val & ~(1 << EN_BIT)) | (1 << BL_BIT));
    delay_us(50);
}

void lcd_send_nibble(unsigned char nibble, unsigned char rs)
{
    unsigned char val;
    val = (nibble << 4) | (rs << RS_BIT) | (1 << BL_BIT);
    lcd_pulse_enable(val);
}

void lcd_send_byte(unsigned char byte, unsigned char rs)
{
    lcd_send_nibble(byte >> 4, rs);
    lcd_send_nibble(byte & 0x0F, rs);
    delay_us(50);
}

void lcd_cmd(unsigned char cmd)
{
    lcd_send_byte(cmd, 0);
}

void lcd_write_char(unsigned char ch)
{
    lcd_send_byte(ch, 1);
}

void lcd_clear(void)
{
    lcd_cmd(0x01);
    delay_ms(2);
}

void lcd_set_cursor(unsigned char col, unsigned char row)
{
    unsigned char addr;
    addr = (row == 0) ? (0x80 + col) : (0xC0 + col);
    lcd_cmd(addr);
}

void lcd_print(char *str)
{
    while(*str)
        lcd_write_char((unsigned char)(*str++));
}

void lcd_show(char *line1, char *line2)
{
    lcd_clear();
    lcd_set_cursor(0, 0);
    lcd_print(line1);
    lcd_set_cursor(0, 1);
    lcd_print(line2);
}

void lcd_init(void)
{
    delay_ms(50);
    lcd_send_nibble(0x03, 0); delay_ms(5);
    lcd_send_nibble(0x03, 0); delay_us(150);
    lcd_send_nibble(0x03, 0);
    lcd_send_nibble(0x02, 0);
    lcd_cmd(0x28);
    lcd_cmd(0x0C);
    lcd_cmd(0x06);
    lcd_cmd(0x01);
    delay_ms(2);
}

bit cup_present(void)
{
    return (IR == 0);
}

void coffee_forward(void) { IN1=1; IN2=0; }
void coffee_reverse(void) { IN1=0; IN2=1; }
void coffee_stop(void)    { IN1=0; IN2=0; }
void sugar_forward(void)  { IN3=1; IN4=0; }
void sugar_reverse(void)  { IN3=0; IN4=1; }
void sugar_stop(void)     { IN3=0; IN4=0; }

void coffee_open(void)
{
    coffee_forward();
    delay_ms(OPEN_TIME);
    coffee_stop();
}

void coffee_close(void)
{
    coffee_reverse();
    delay_ms(CLOSE_TIME);
    coffee_stop();
}

void sugar_open(void)
{
    sugar_forward();
    delay_ms(OPEN_TIME);
    sugar_stop();
}

void sugar_close(void)
{
    sugar_reverse();
    delay_ms(CLOSE_TIME);
    sugar_stop();
}

void auto_mode(void)
{
    coffee_open();
    delay_ms(AUTO_COFFEE_TIME);
    coffee_close();
    delay_ms(500);
    sugar_open();
    delay_ms(AUTO_SUGAR_TIME);
    sugar_close();
}

void main(void)
{
    P1 = 0xFF;
    P2 = 0x00;
    P3 = 0xFF;

    lcd_init();
    lcd_show("  Coffee Maker  ", "");
    delay_ms(2000);

    coffee_close();
    sugar_close();

    while(1)
    {
        if(!cup_present())
        {
            lcd_show("  Coffee Maker  ", " Place the Cup  ");
        }
        else
        {
            lcd_show("  Coffee Maker  ", "A=Cof B=Sug C=Au");

            if(BTN_A == 0)
            {
                lcd_show("Dispensing", "Coffee...");
                coffee_open();
                while(BTN_A == 0);
                coffee_close();
                lcd_show("Coffee", "Done!");
                delay_ms(1000);
            }
            else if(BTN_B == 0)
            {
                lcd_show("Dispensing", "Sugar...");
                sugar_open();
                while(BTN_B == 0);
                sugar_close();
                lcd_show("Sugar", "Done!");
                delay_ms(1000);
            }
            else if(BTN_AUTO == 0)
            {
                delay_ms(20);
                if(BTN_AUTO == 0)
                {
                    lcd_show("Automatic Mode", "Running...");
                    auto_mode();
                    lcd_show("Automatic Mode", "Done!");
                    delay_ms(1000);
                    while(BTN_AUTO == 0);
                }
            }
        }
    }
}
